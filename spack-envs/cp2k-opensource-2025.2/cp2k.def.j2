# Apptainer Definition File for CP2K Opensource 2025.2
# Generated by: python generate.py build-sif --app-version cp2k-opensource-2025.2
#
# This file is a Jinja2 template. It is rendered by generate.py at build time.
# Do NOT edit the rendered .def file directly — edit this template instead.
#
# Bootstrap source: docker-archive (OCI tar exported by podman/docker)
# The tar file is exported from the locally built image and placed alongside the SIF output.

Bootstrap: docker-archive
From: {{ docker_tar_filename }}

# ── Labels ───────────────────────────────────────────────────────────────
%labels
    Maintainer s8ga
    Version {{ default_image_tag }}
    Org.opencontainers.image.description CP2K {{ default_image_tag }} with opensource BLAS
    Org.opencontainers.image.source https://github.com/cp2k/cp2k

# ── Environment variables (set at RUNTIME) ───────────────────────────────
# NOTE: ENV from Dockerfile (HPC_CONTAINER_NAME, HPC_CONTAINER_TAG,
# HPC_CONTAINER_BUILD_TS, CP2K_DATA_DIR, PATH, etc.) are automatically
# preserved by Apptainer when building from docker-archive.
#
# MOTD strategy:
#   apptainer shell launches bash with --norc, which skips /etc/bash.bashrc,
#   ~/.bashrc, and BASH_ENV — so none of those hooks work.
#
#   The shell action script (/.singularity.d/actions/shell) checks
#   SINGULARITY_SHELL first: if set and executable, it exec's that instead
#   of the default "bash --norc".  We use this to inject a thin wrapper that
#   shows the MOTD and then exec's "bash --norc" — no ~/.bashrc side effects.
#
#   SINGULARITY_SHELL is only consulted by the *shell* action; exec/run
#   ignore it entirely, so the MOTD never fires there.
%environment
    export SINGULARITY_SHELL="/usr/local/bin/hpc-shell-wrapper.sh"

# ── Post-install: MOTD shell wrapper ─────────────────────────────────────
%post
    # Create a thin wrapper used as SINGULARITY_SHELL.
    # It shows the MOTD (only when invoked by "apptainer shell") and then
    # exec's bash --norc to preserve the default Apptainer shell experience.
    cat > /usr/local/bin/hpc-shell-wrapper.sh <<'WRAPPER_EOF'
#!/bin/bash
if [ "${APPTAINER_COMMAND:-}" = "shell" ]; then
    /usr/local/bin/hpc-motd.sh 2>/dev/null || true
fi
exec /bin/bash --norc "$@"
WRAPPER_EOF
    chmod 755 /usr/local/bin/hpc-shell-wrapper.sh

# ── Runscript (apptainer run) ────────────────────────────────────────────
%runscript
    exec "$@"

# ── Help ─────────────────────────────────────────────────────────────────
%help
    CP2K {{ default_image_tag }} with opensource BLAS

    Usage:
      apptainer shell <image>.sif           # Interactive shell (MOTD shown)
      apptainer exec <image>.sif cp2k.psmp  # Run CP2K directly
      apptainer run <image>.sif             # Execute runscript

    Environment:
      CP2K_DATA_DIR    - Basis sets and potentials
      OMP_NUM_THREADS  - OpenMP threads per rank (default: 1 recommended)
