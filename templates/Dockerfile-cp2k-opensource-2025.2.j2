# Multi-stage Dockerfile for CP2K + Opensource BLAS 2025.2 with Spack
# BUILD REQUIREMENTS:
# - assets/ directory with spack-v1.1.0.tar.gz, bootstrap-cache, spack-mirror (optional)
# - spack-envs/cp2k-opensource-2025.2 with spack.yaml and spack.lock
# 
#
# NOTE: 不要修改各 stage 内的 RUN 步骤，否则会破坏构建缓存。

ARG DEFAULT_IMAGE_NAME="{{ default_image_name }}"
ARG DEFAULT_IMAGE_TAG="{{ default_image_tag }}"

# ============================================================================
# STAGE 1: BUILDER - CP2K compilation environment
# ============================================================================
FROM {{ builder_base_image }} AS builder

LABEL stage="builder" \
      description="Builder stage: Compiles CP2K 2025.2 with Spack" \
      maintainer="s8ga"

{% include "Dockerfile-base.j2" %}

# ============================================================================
# CP2K-SPECIFIC BUILD
# ============================================================================

# Fetch the CP2K source file
RUN echo "Fetching cp2k source file, this will take a long time if your connection is bad" && \
    git clone --depth 1 --recursive -b support/v2025.2 https://github.com/cp2k/cp2k.git /opt/cp2k

# Prepare the spack environment + configuration
COPY spack-envs/cp2k-opensource-2025.2 /opt/spack-env-file

# Create env, then import lock/config/repos from source directory.
RUN /bin/bash -c 'set -euo pipefail; \
    spack env create cp2k-env /opt/spack-env-file/spack.yaml && \
    if [ -f /opt/spack-env-file/spack.lock ]; then \
        cp -f /opt/spack-env-file/spack.lock "${SPACK_ROOT}/var/spack/environments/cp2k-env/spack.lock"; \
        echo "Imported existing spack.lock"; \
    else \
        echo "No spack.lock provided; install step will concretize"; \
    fi'

# Find all compilers + all external packages
RUN spack compiler find && \
    spack external find --all --not-buildable

# Add custom spack repo from CP2K developers
RUN mkdir -p /opt/spack-repo/spack_repo/ && \
    cp -a /opt/cp2k/tools/spack/cp2k_dev_repo/ /opt/spack-repo/spack_repo/ && \
    spack repo add --scope site /opt/spack-repo/spack_repo/cp2k_dev_repo/ && \
    spack -e cp2k-env repo ls

ENV SPACK_ENV_VIEW="${SPACK_ROOT}/var/spack/environments/cp2k-env/view"

# Special Fix for compile Openmp@5.0.8
# checking for zlib library (z) in /usr... not found

RUN ln -sf /usr/lib/x86_64-linux-gnu/libz.so /usr/lib/libz.so

RUN sed -i -e 's/myenv/cp2k-env/g' -e '/-DCP2K_USE_LIBXSMM=OFF/d' -e '/-DCP2K_USE_TBLITE=OFF/d' /opt/cp2k/cmake/cmake_cp2k.sh

RUN {% if use_mirror %}
    --mount=type=bind,source=assets/spack-mirror,target=/opt/spack-mirror,readonly \
    {% endif %}
        spack -e cp2k-env install --fail-fast -j "$(nproc)"; \
        spack -e cp2k-env gc -y
    
# Extract output artifact
RUN mkdir -p /opt/spack && \
    cp -ar ${SPACK_ENV_VIEW}/bin ${SPACK_ENV_VIEW}/include ${SPACK_ENV_VIEW}/lib /opt/spack

# Compile CP2K
ENV CP2K_VERSION="psmp"
WORKDIR /opt/cp2k
RUN /bin/bash -c -o pipefail "source ./cmake/cmake_cp2k.sh spack_all psmp"

# Compile CP2K for target CPU x86_64
ENV LOG_LINES=-200
WORKDIR /opt/cp2k/build
RUN /bin/bash -c -o pipefail " \
    echo -e '\nCompiling CP2K ... \c'; \
    if ninja --verbose &>ninja.log; then \
      echo -e 'done\n'; \
      echo -e 'Installing CP2K ... \c'; \
      if ninja --verbose install &>install.log; then \
        echo -e 'done\n'; \
      else \
        echo -e 'failed\n'; \
        tail -n ${LOG_LINES} install.log; \
      fi; \
      cat cmake.log ninja.log install.log | gzip >build_cp2k.log.gz; \
    else \
      echo -e 'failed\n'; \
      tail -n ${LOG_LINES} ninja.log; \
      cat cmake.log ninja.log | gzip >build_cp2k.log.gz; \
    fi"

# Store build arguments from base image needed in next stage
RUN echo "${CP2K_VERSION}" >/CP2K_VERSION


# ----------------------------------------------------------------------------
# STEP: Strip debug symbols
# ----------------------------------------------------------------------------
RUN find /opt/spack/bin -type f -exec strip {} \; 2>/dev/null || true && \
    find /opt/cp2k/build/bin -type f -exec strip {} \; 2>/dev/null || true && \
    find /opt/spack/lib -name "*.so*" -type f -exec strip {} \; 2>/dev/null || true && \
    echo "Runtime lib size: $(du -sh /opt/spack/ | cut -f1)" || true && \
    echo "Runtime bin size: $(du -sh /opt/cp2k/build/bin | cut -f1)"

# ----------------------------------------------------------------------------
# STEP: Build manifest
# ----------------------------------------------------------------------------
#RUN . /opt/spack/share/spack/setup-env.sh && spack env activate . && \
#    { echo "=== CP2K 2025.2 Build Manifest ==="; \
#      echo "Generated: $(date)"; \
#      echo "View: $(du -sh /opt/hpc-view/ | cut -f1)"; \
#      echo "Runtime: $(du -sh /opt/hpc-runtime/ | cut -f1)"; \
#      echo ""; spack find -d; } > /opt/hpc-runtime/BUILD_MANIFEST.txt && \
#      echo "=== Generating Dependency Graph ===" && \
#      spack graph --color --dot > /opt/hpc-runtime/DependencyGraph.dot && \
#      echo "Dependency graph saved: DependencyGraph.dot" && \
#      wc -l /opt/hpc-runtime/DependencyGraph.dot

{% if not build_only %}
# ============================================================================
# STAGE 2: RUNTIME - Minimal container with only CP2K and runtime libraries
# ============================================================================
FROM {{ runtime_base_image }} AS runtime

LABEL stage="runtime" \
      description="Runtime stage: Minimal container with CP2K 2025.2 only" \
      maintainer="s8ga"

# Minimal runtime: only cp2k.psmp + mpirun + required .so files
# CP2K_DATA_DIR points to basis sets, potentials, and other data files
ENV DEBIAN_FRONTEND=noninteractive \
    PATH="/opt/spack/bin:/opt/cp2k/bin:/opt/bin:$PATH" \
    LD_LIBRARY_PATH="/opt/spack/lib:/opt/lib:$LD_LIBRARY_PATH" \
    CP2K_DATA_DIR="/opt/share/cp2k/data" 


# Configure APT mirrors to use USTC (中科大) for faster downloads in China
RUN sed -i 's|deb.debian.org|mirrors.ustc.edu.cn|g' /etc/apt/sources.list.d/*.sources 2>/dev/null || true && \
    sed -i 's|deb.debian.org|mirrors.ustc.edu.cn|g' /etc/apt/sources.list 2>/dev/null || true && \
    sed -i 's|security.debian.org|mirrors.ustc.edu.cn/debian-security|g' /etc/apt/sources.list 2>/dev/null || true

# Install minimal runtime dependencies (system libraries not included in spack view)
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    ca-certificates \
    libc6 \
    openssh-client \
    tar \
    perl \
    nano \
    curl \
    python3 \
    bash \
    g++ \
    gcc \
    gfortran \
    screen \
    util-linux \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Create non-root user for security (before COPY to use --chown)
RUN useradd -m -s /bin/bash hpc

# Copy minimal runtime from builder with correct ownership
# Using --chown avoids creating duplicate layer from chown -R
WORKDIR /opt
COPY --from=builder --chown=hpc:hpc  /CP2K_VERSION /
COPY --from=builder --chown=hpc:hpc /opt/spack ./spack
COPY --from=builder --chown=hpc:hpc /opt/cp2k/bin ./bin
COPY --from=builder --chown=hpc:hpc /opt/cp2k/lib ./lib
COPY --from=builder --chown=hpc:hpc /opt/cp2k/share ./share
COPY --from=builder --chown=hpc:hpc /opt/cp2k/tests ./tests
COPY --from=builder --chown=hpc:hpc /opt/cp2k/src/grid/sample_tasks ./src/grid/sample_tasks
COPY --from=builder --chown=hpc:hpc /opt/cp2k/build/build_cp2k.log.gz /opt/cp2k/build/build_cp2k.log.gz

# Update library search path
RUN TORCH_LIB_PATH=$(dirname $(find /opt/spack/lib -name libtorch.so 2>/dev/null || true) 2>/dev/null || true) && \
    { echo "/opt/cp2k/lib"; echo "/opt/spack/lib"; [ -n "$TORCH_LIB_PATH" ] && echo "$TORCH_LIB_PATH"; } >/etc/ld.so.conf.d/cp2k.conf && \
    ldconfig

# Remove static libraries to save space
RUN find /opt -name "*.a" -delete 2>/dev/null || true && \
    echo "Static libraries removed"

# Create workspace directory
RUN mkdir -p /workspace && chown hpc:hpc /workspace

# Set working directory
WORKDIR /workspace

# Switch to non-root user
USER hpc

# ============================================================================
# STAGE 3: FINAL - Alias for runtime (for backward compatibility)
# ============================================================================
FROM runtime AS final

ARG DEFAULT_IMAGE_NAME="{{ default_image_name }}"
ARG DEFAULT_IMAGE_TAG="{{ default_image_tag }}"

LABEL version="2025.2" \
      description="Optimized CP2K 2025.2 container" \
      maintainer="s8ga" \
      image_name="{{ default_image_name }}" \
      image_tag="{{ default_image_tag }}" \
      timestamp="{{ timestamp }}"
{% endif %}

# ============================================================================
# END OF DOCKERFILE
# ============================================================================
